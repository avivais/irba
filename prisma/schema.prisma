// IRBA Manager — PostgreSQL via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlayerKind {
  REGISTERED
  DROP_IN
}

enum Position {
  PG
  SG
  SF
  PF
  C
}

enum PaymentMethod {
  CASH
  PAYBOX
  BIT
  BANK_TRANSFER
  OTHER
}

enum ChargeType {
  REGISTERED
  DROP_IN
  ADMIN_OVERRIDE
}

model Player {
  id          String     @id @default(cuid())
  phone       String     @unique
  playerKind  PlayerKind @default(DROP_IN)
  positions   Position[] @default([])
  rank        Float?
  isAdmin     Boolean    @default(false)
  nickname    String?
  firstNameHe String?
  lastNameHe  String?
  firstNameEn String?
  lastNameEn  String?
  birthdate   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  email         String?
  nationalId    String?
  passwordHash  String?
  otpCode       String?
  otpExpiresAt  DateTime?
  emailVerified Boolean   @default(false)

  regulationsAcceptedAt      DateTime?
  regulationsAcceptedVersion Int?

  computedRank Float?

  attendances    Attendance[]
  yearAggregates PlayerYearAggregate[]
  adjustments    PlayerAdjustment[]
  payments       Payment[]
  sessionCharges SessionCharge[]

  @@index([phone])
  @@index([nickname])
  @@index([email])
}

model GameSession {
  id              String   @id @default(cuid())
  date            DateTime
  maxPlayers      Int      @default(15)
  isClosed             Boolean   @default(false)
  isArchived           Boolean   @default(false)
  isCharged            Boolean   @default(false)
  alertEarlyFiredAt    DateTime?
  alertCriticalFiredAt DateTime?
  durationMinutes Int?
  locationName    String?
  locationLat     Float?
  locationLng     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances    Attendance[]
  sessionCharges SessionCharge[]
  matches        Match[]

  @@index([date])
}

model Match {
  id             String   @id @default(cuid())
  sessionId      String
  teamAPlayerIds String[]
  teamBPlayerIds String[]
  scoreA         Int
  scoreB         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model YearWeight {
  year   Int   @id
  weight Float
}

model PlayerYearAggregate {
  id       String @id @default(cuid())
  playerId String
  year     Int
  count    Int    @default(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, year])
  @@index([playerId])
}

model PlayerAdjustment {
  id          String   @id @default(cuid())
  playerId    String
  date        DateTime
  points      Float
  description String
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model Attendance {
  id            String   @id @default(cuid())
  playerId      String
  gameSessionId String
  createdAt     DateTime @default(now())

  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameSessionId])
  @@index([gameSessionId, createdAt])
}

model Payment {
  id          String        @id @default(cuid())
  playerId    String
  date        DateTime
  amount      Int
  method      PaymentMethod @default(BIT)
  description String?
  createdAt   DateTime      @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([date])
}

model SessionCharge {
  id               String      @id @default(cuid())
  sessionId        String
  playerId         String
  amount           Int
  calculatedAmount Int
  chargeType       ChargeType
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  session      GameSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player       Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  auditEntries ChargeAuditEntry[]

  @@unique([sessionId, playerId])
  @@index([sessionId])
  @@index([playerId])
}

model ChargeAuditEntry {
  id              String   @id @default(cuid())
  sessionChargeId String
  changedAt       DateTime @default(now())
  changedBy       String
  previousAmount  Int
  newAmount       Int
  reason          String?

  sessionCharge SessionCharge @relation(fields: [sessionChargeId], references: [id], onDelete: Cascade)

  @@index([sessionChargeId])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model HourlyRate {
  id            String   @id @default(cuid())
  effectiveFrom DateTime @db.Date
  pricePerHour  Float
  createdAt     DateTime @default(now())

  @@index([effectiveFrom])
}

model PeerRatingSession {
  id        String     @id @default(cuid())
  year      Int        @unique
  openedAt  DateTime   @default(now())
  closedAt  DateTime?
  openedBy  String

  ratings PeerRating[]
}

model PeerRating {
  id              String   @id @default(cuid())
  ratingSessionId String
  raterId         String
  ratedPlayerId   String
  position        Int
  submittedAt     DateTime @default(now())

  session PeerRatingSession @relation(fields: [ratingSessionId], references: [id], onDelete: Cascade)

  @@unique([ratingSessionId, raterId, ratedPlayerId])
  @@index([ratingSessionId])
  @@index([raterId])
}

model Challenge {
  id                 String   @id @default(cuid())
  title              String
  metric             String   // "win_ratio" | "total_wins" | "attendance"
  eligibilityMinPct  Float    // min % of sessions in window a player must attend to qualify
  roundCount         Int      // number of rounds the window spans; 0 = all-time
  prize              String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  createdBy          String   // playerId of admin who created it
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())
  actor      String
  actorIp    String?
  action     String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?

  @@index([timestamp(sort: Desc)])
  @@index([action])
  @@index([entityType, entityId])
  @@index([actor])
}
