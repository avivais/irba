// IRBA Manager — PostgreSQL via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlayerKind {
  REGISTERED
  DROP_IN
}

enum Position {
  PG
  SG
  SF
  PF
  C
}

model Player {
  id          String     @id @default(cuid())
  name        String
  phone       String     @unique
  playerKind  PlayerKind @default(DROP_IN)
  positions   Position[] @default([])
  rank        Float?
  balance     Int        @default(0)
  isAdmin     Boolean    @default(false)
  nickname    String?
  firstNameHe String?
  lastNameHe  String?
  firstNameEn String?
  lastNameEn  String?
  birthdate   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  attendances    Attendance[]
  yearAggregates PlayerYearAggregate[]
  adjustments    PlayerAdjustment[]
  payments       Payment[]

  @@index([phone])
  @@index([nickname])
}

model GameSession {
  id         String   @id @default(cuid())
  date       DateTime
  maxPlayers Int      @default(15)
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attendances Attendance[]

  @@index([date])
}

model YearWeight {
  year   Int   @id
  weight Float
}

model PlayerYearAggregate {
  id       String @id @default(cuid())
  playerId String
  year     Int
  count    Int    @default(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, year])
  @@index([playerId])
}

model PlayerAdjustment {
  id          String   @id @default(cuid())
  playerId    String
  date        DateTime
  points      Float
  description String
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model Attendance {
  id            String   @id @default(cuid())
  playerId      String
  gameSessionId String
  createdAt     DateTime @default(now())

  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameSessionId])
  @@index([gameSessionId, createdAt])
}

model Payment {
  id          String   @id @default(cuid())
  playerId    String
  date        DateTime
  amount      Int
  description String?
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([date])
}
