# Copy to .env and adjust. Never commit real secrets.

# Local dev (Next on host, Postgres in Docker): use localhost and published port.
# DATABASE_URL="postgresql://irba:irba_dev_password@localhost:5432/irba"

# App container (docker compose): hostname is the db service name.
# DATABASE_URL="postgresql://irba:irba_dev_password@db:5432/irba"

POSTGRES_USER=irba
POSTGRES_PASSWORD=irba_dev_password
POSTGRES_DB=irba
POSTGRES_PORT=5432

DATABASE_URL="postgresql://irba:irba_dev_password@localhost:5432/irba"

# Min 32 chars — used to sign the RSVP session cookie (jose HS256).
RSVP_SESSION_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Admin area (/admin): separate secret + bcrypt hash of the operator password (never commit real values).
# Set hash: npm run hash-admin-password (writes `.env` with correct `$` escaping for Next.js)
ADMIN_SESSION_SECRET="change-me-admin-session-secret-min-32-chars-long"
# Bcrypt uses `$` — Next.js expands `$var` via dotenv-expand; the script writes `\$` in single quotes so the hash survives.
ADMIN_PASSWORD_HASH=''

# Optional admin JWT claims (defaults: issuer irba, audience irba-admin).
# ADMIN_JWT_ISSUER=irba
# ADMIN_JWT_AUDIENCE=irba-admin

# Admin session cookie max-age in seconds (default 14 days, min 300, max 90 days).
# ADMIN_SESSION_MAX_AGE_SEC=1209600

# Set to 1/true when the app is served over HTTPS but NODE_ENV is not production (e.g. staging).
# RSVP_COOKIE_SECURE=1

# Optional JWT claims — defaults keep cookies scoped to this app only.
# RSVP_JWT_ISSUER=irba
# RSVP_JWT_AUDIENCE=irba-rsvp

# RSVP rate limits (in-memory per app process). Max requests per sliding window per client IP.
# IRBA_RL_ATTEND_MAX=15
# IRBA_RL_ATTEND_WINDOW_MS=900000
# IRBA_RL_CANCEL_MAX=30
# IRBA_RL_CANCEL_WINDOW_MS=900000

# Admin login rate limit (in-memory per process, same caveats as RSVP limits).
# IRBA_RL_ADMIN_LOGIN_MAX=10
# IRBA_RL_ADMIN_LOGIN_WINDOW_MS=900000

# --- Optional: random QA seed (scripts/seed-random.ts) ---
# IRBA_ALLOW_RANDOM_SEED=1
# IRBA_SEED_RESET=1
# IRBA_RANDOM_PLAYERS=28
# IRBA_SEED_FAKER_SEED=12345
