{
  "name": "irba",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start & echo $! > .next.pid && wait $!",
    "stop": "kill $(cat .next.pid 2>/dev/null) 2>/dev/null; kill $(cat .cloudflared.pid 2>/dev/null) 2>/dev/null; rm -f .next.pid .cloudflared.pid; true",
    "web": "cloudflared tunnel --url http://localhost:3000 & echo $! > .cloudflared.pid && wait $!",
    "startweb": "npm start & cloudflared tunnel --url http://localhost:3000 & echo $! > .cloudflared.pid && wait $!",
    "buildandstartweb": "npm run build && npm start & cloudflared tunnel --url http://localhost:3000 & echo $! > .cloudflared.pid && wait $!",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:random": "tsx scripts/seed-random.ts",
    "hash-admin-password": "tsx scripts/hash-admin-password.ts",
    "generate-admin-secret": "tsx scripts/generate-admin-secret.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
